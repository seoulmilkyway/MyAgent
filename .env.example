# LLM Settings
LLM_PROVIDER="ollama"  # ollama, openai, gemini
OLLAMA_MODEL="gemma4:e4b" # User's specified model
OLLAMA_BASE_URL="http://localhost:11434"

# Output Settings
USE_STREAMING="true" # true: 실시간 스트리밍 출력, false: 완료 후 일괄 출력

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langchain-api-key"
LANGCHAIN_PROJECT="MyAgent-Local"

# OpenAI / Gemini API Keys
OPENAI_API_KEY="your-openai-api-key"
GOOGLE_API_KEY="your-google-api-key"

# Web Search Settings
SEARCH_PROVIDER="duckduckgo" # duckduckgo, tavily, google
TAVILY_API_KEY="your-tavily-api-key"
SERPAPI_API_KEY="your-serpapi-api-key"
